# Ansible managed NFS exports for Compute Nodes
# TODO: change to subnet? mount only /opt/clustron_share?
{% if 'compute_nodes' in groups %}
{% for host in groups['compute_nodes'] %}
{% if hostvars[host]['ansible_default_ipv4'] is defined and hostvars[host]['ansible_default_ipv4']['address'] is defined %}
{% set real_ip = hostvars[host]['ansible_default_ipv4']['address'] %}
/home       {{ real_ip }}(rw,sync,no_subtree_check,no_root_squash)
/opt        {{ real_ip }}(rw,sync,no_subtree_check,no_root_squash)
/etc/slurm  {{ real_ip }}(rw,sync,no_subtree_check,no_root_squash)
{% endif %}
{% endfor %}
{% endif %}
