[sssd]
services = nss, pam, ssh
domains = default

[domain/default]
id_provider = ldap
auth_provider = ldap

ldap_uri = ldap://{{ head_node_ip }}

ldap_search_base = dc=clustron,dc=prj,dc=internal,dc=sdc,dc=nycu,dc=club

ldap_user_ssh_public_key = sshPublicKey

// TODO: change password?
ldap_default_bind_dn = cn=admin,dc=clustron,dc=prj,dc=internal,dc=sdc,dc=nycu,dc=club
ldap_default_authtok = admin123

ldap_id_use_start_tls = false
ldap_tls_reqcert = allow
enumerate = false
cache_credentials = false
